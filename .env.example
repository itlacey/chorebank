# ChoreBank environment variables
# Copy to .env for local development: cp .env.example .env

# Django secret key (REQUIRED in production)
SECRET_KEY=django-insecure-dev-only-change-in-production

# Debug mode (default: True for local dev)
DEBUG=True

# Allowed hosts (comma-separated, e.g.: .up.railway.app,localhost)
ALLOWED_HOSTS=localhost,127.0.0.1

# CSRF trusted origins (comma-separated, e.g.: https://*.up.railway.app)
CSRF_TRUSTED_ORIGINS=

# Database URL (default: SQLite for local dev)
# Railway provides this automatically for Postgres
DATABASE_URL=
